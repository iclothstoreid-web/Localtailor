<script>
  const labels = ['','Perlu peningkatan','Cukup baik','Baik','Sangat baik','Luar biasa — Masya Allah!'];
  let selected = 0;
  const stars = document.querySelectorAll('.star');
  const lbl   = document.getElementById('ratingLabel');

  stars.forEach(s => {
    s.addEventListener('mouseenter', () => highlight(+s.dataset.val));
    s.addEventListener('mouseleave', () => highlight(selected));
    s.addEventListener('click', () => {
      selected = +s.dataset.val;
      highlight(selected);
      lbl.textContent = labels[selected];
    });
  });

  function highlight(n) {
    stars.forEach(s => s.classList.toggle('active', +s.dataset.val <= n));
    if (n > 0 && n !== selected) lbl.textContent = labels[n];
  }

  function submitRating() {
    if (!selected) { lbl.textContent = 'Silakan pilih bintang terlebih dahulu.'; return; }
    document.querySelector('.rating-submit').style.display = 'none';
    document.querySelector('.rating-textarea').style.display = 'none';
    document.querySelector('.stars').style.display = 'none';
    document.querySelector('.rating-sub').style.display = 'none';
    document.querySelector('.rating-title').style.display = 'none';
    document.getElementById('ratingLabel').style.display = 'none';
    document.getElementById('ratingThanks').style.display = 'block';
  }
</script>

