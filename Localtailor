<!-- MAIN -->
<main>

  <!-- ITEM -->
  <div class="section-label">Detail Karya</div>
  <div class="item-card">
    <div class="item-thumb">
      <svg width="28" height="34" viewBox="0 0 28 34" fill="none" stroke="#B89A6A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2C10 2 7 5 7 8v2H4l-2 6h4v14h16V16h4l-2-6h-3V8c0-3-3-6-7-6z"/>
        <line x1="14" y1="10" x2="14" y2="20"/>
      </svg>
    </div>
