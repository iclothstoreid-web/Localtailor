<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Perjalanan Pesanan – Local Tailor</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream:   #F7F4EF;
      --sand:    #E8E1D5;
      --ink:     #1A1814;
      --muted:   #6B6459;
      --gold:    #B89A6A;
      --gold-lt: #D4B98A;
      --white:   #FFFFFF;
      --done:    #B89A6A;
      --pending: #C8BFB4;
      --green:   #2D6A4F;
    }

    html { font-size: 16px; }
    body {
      background: var(--cream);
      color: var(--ink);
      font-family: 'DM Sans', sans-serif;
      font-weight: 300;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── HEADER ── */
    header {
      background: var(--ink);
      padding: 1.1rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.3rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      color: var(--white);
      text-transform: uppercase;
    }
    .logo span { color: var(--gold); }
    .header-tag {
      font-size: 0.62rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
    }

    /* ── BISMILLAH BAND ── */
    .bismillah-band {
      background: var(--green);
      padding: 0.55rem 1.5rem;
      text-align: center;
    }
    .bismillah-ar {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      color: var(--gold-lt);
      letter-spacing: 0.05em;
    }
    .bismillah-tr {
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.45);
      margin-top: 0.15rem;
    }

    /* ── HERO ── */
    .hero {
      background: var(--ink);
      padding: 2.25rem 1.5rem 2.75rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
    }
    .hero::after {
      content: '';
      position: absolute;
      bottom: 0; left: 50%;
      transform: translateX(-50%);
      width: 48px; height: 1px;
      background: var(--gold);
    }
    .hero-eyebrow {
      font-size: 0.6rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.6rem;
    }
    .hero-greeting {
      font-size: 0.75rem;
      color: rgba(255,255,255,0.45);
      margin-bottom: 0.25rem;
      letter-spacing: 0.05em;
    }
    .hero-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem;
      font-weight: 400;
      color: var(--white);
      line-height: 1.15;
      margin-bottom: 0.5rem;
    }
    .hero-name em {
      font-style: italic;
      color: var(--gold-lt);
    }
    .hero-order {
      font-size: 0.68rem;
      letter-spacing: 0.15em;
      color: var(--muted);
      text-transform: uppercase;
    }

    /* ── MAIN ── */
    main {
      flex: 1;
      padding: 2rem 1.25rem 3rem;
      max-width: 480px;
      margin: 0 auto;
      width: 100%;
    }

    /* ── SECTION LABEL ── */
    .section-label {
      font-size: 0.58rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.15rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--sand);
    }

    /* ── ITEM CARD ── */
    .item-card {
      background: var(--white);
      border-radius: 2px;
      padding: 1.25rem;
      margin-bottom: 2rem;
      display: flex;
      gap: 1rem;
      align-items: flex-start;
      box-shadow: 0 1px 8px rgba(26,24,20,0.06);
    }
    .item-thumb {
      width: 64px; height: 80px;
      background: var(--sand);
      border-radius: 1px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .item-thumb svg { opacity: 0.4; }
    .item-info { flex: 1; }
    .item-type {
      font-size: 0.58rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.2rem;
    }
    .item-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      font-weight: 600;
      line-height: 1.2;
      margin-bottom: 0.5rem;
    }
    .item-meta {
      font-size: 0.71rem;
      color: var(--muted);
      line-height: 1.7;
    }
    .item-meta b { color: var(--ink); font-weight: 500; }
    .est-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      background: var(--sand);
      border-radius: 20px;
      padding: 0.28rem 0.7rem;
      font-size: 0.68rem;
      color: var(--muted);
      margin-top: 0.55rem;
    }
    .est-badge b { color: var(--ink); font-weight: 500; }

    /* ── TIMELINE ── */
    .timeline { position: relative; margin-bottom: 2rem; }
    .tl-step {
      display: flex;
      gap: 1rem;
      padding-bottom: 1.75rem;
    }
    .tl-step:last-child { padding-bottom: 0; }
    .tl-left {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 28px;
      flex-shrink: 0;
    }
    .tl-dot {
      width: 28px; height: 28px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      font-size: 0.62rem;
      font-weight: 500;
    }
    .tl-dot.done    { background: var(--done); color: var(--white); }
    .tl-dot.active  { background: var(--ink); color: var(--white); animation: pulse 2.4s ease-in-out infinite; }
    .tl-dot.pending { background: var(--sand); color: var(--muted); }
    @keyframes pulse {
      0%,100% { box-shadow: 0 0 0 4px rgba(184,154,106,0.18); }
      50%      { box-shadow: 0 0 0 8px rgba(184,154,106,0.06); }
    }
    .tl-line {
      flex: 1; width: 1px; margin-top: 4px;
      background: var(--sand); min-height: 20px;
    }
    .tl-line.done { background: var(--gold); }
    .tl-step:last-child .tl-line { display: none; }
    .tl-body { flex: 1; padding-top: 4px; }
    .tl-title {
      font-size: 0.85rem;
      font-weight: 500;
      margin-bottom: 0.15rem;
    }
    .tl-step.pending .tl-title { color: var(--muted); }
    .tl-sub {
      font-size: 0.72rem;
      color: var(--muted);
      line-height: 1.55;
    }
    .tl-date {
      font-size: 0.63rem;
      letter-spacing: 0.05em;
      color: var(--gold);
      margin-top: 0.2rem;
      font-weight: 500;
    }
    .tl-photo {
      margin-top: 0.65rem;
      width: 100%;
      max-width: 210px;
      aspect-ratio: 4/3;
      background: var(--sand);
      border-radius: 2px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .tl-photo-placeholder {
      font-size: 0.6rem;
      color: var(--muted);
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    /* ── ARTISAN CARD ── */
    .artisan-card {
      background: var(--white);
      border-radius: 2px;
      padding: 1.35rem 1.25rem;
      margin-bottom: 2rem;
      box-shadow: 0 1px 8px rgba(26,24,20,0.06);
      display: flex;
      gap: 1rem;
      align-items: flex-start;
    }
    .artisan-avatar {
      width: 72px; height: 72px;
      border-radius: 50%;
      background: var(--sand);
      flex-shrink: 0;
      overflow: hidden;
      border: 2px solid var(--gold);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .artisan-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .artisan-avatar-placeholder {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem;
      color: var(--gold);
      font-weight: 600;
    }
    .artisan-info { flex: 1; }
    .artisan-label {
      font-size: 0.58rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.2rem;
    }
    .artisan-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      font-weight: 600;
      line-height: 1.2;
      margin-bottom: 0.3rem;
    }
    .artisan-spec {
      font-size: 0.72rem;
      color: var(--muted);
      line-height: 1.6;
    }
    .artisan-spec b { color: var(--ink); font-weight: 500; }
    .artisan-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      background: #F0EBE3;
      border-radius: 20px;
      padding: 0.25rem 0.65rem;
      font-size: 0.65rem;
      color: var(--muted);
      margin-top: 0.5rem;
    }
    .artisan-badge b { color: var(--gold); font-weight: 600; }

    /* ── RATING ── */
    .rating-card {
      background: var(--white);
      border-radius: 2px;
      padding: 1.35rem 1.25rem;
      margin-bottom: 2rem;
      box-shadow: 0 1px 8px rgba(26,24,20,0.06);
    }
    .rating-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.05rem;
      font-weight: 600;
      margin-bottom: 0.25rem;
    }
    .rating-sub {
      font-size: 0.72rem;
      color: var(--muted);
      margin-bottom: 1rem;
      line-height: 1.5;
    }
    .stars {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }
    .star {
      font-size: 1.75rem;
      cursor: pointer;
      color: var(--sand);
      transition: color 0.15s, transform 0.15s;
      user-select: none;
      line-height: 1;
    }
    .star:hover,
    .star.active { color: var(--gold); transform: scale(1.15); }
    .rating-label {
      font-size: 0.72rem;
      color: var(--muted);
      margin-bottom: 0.75rem;
      min-height: 1rem;
      font-style: italic;
      transition: opacity 0.2s;
    }
    .rating-textarea {
      width: 100%;
      border: 1px solid var(--sand);
      border-radius: 2px;
      padding: 0.75rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.78rem;
      color: var(--ink);
      resize: none;
      background: var(--cream);
      outline: none;
      line-height: 1.5;
      transition: border-color 0.2s;
    }
    .rating-textarea:focus { border-color: var(--gold); }
    .rating-textarea::placeholder { color: var(--muted); }
    .rating-submit {
      margin-top: 0.75rem;
      width: 100%;
      background: var(--ink);
      color: var(--white);
      border: none;
      padding: 0.8rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.72rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      cursor: pointer;
      border-radius: 1px;
      transition: background 0.2s;
    }
    .rating-submit:hover { background: #2e2b26; }
    .rating-thanks {
      display: none;
      text-align: center;
      padding: 1rem 0;
    }
    .rating-thanks-ar {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      color: var(--gold);
      margin-bottom: 0.25rem;
    }
    .rating-thanks-text {
      font-size: 0.75rem;
      color: var(--muted);
      line-height: 1.6;
    }

    /* ── NOTE ── */
    .note-card {
      background: var(--white);
      border-left: 2px solid var(--gold);
      padding: 1rem 1.1rem;
      border-radius: 0 2px 2px 0;
      margin-bottom: 2rem;
    }
    .note-label {
      font-size: 0.58rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.35rem;
    }
    .note-text {
      font-size: 0.78rem;
      color: var(--muted);
      line-height: 1.65;
    }

    /* ── CTA ── */
    .cta-wrap { text-align: center; }
    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--ink);
      color: var(--white);
      text-decoration: none;
      padding: 0.8rem 1.75rem;
      font-size: 0.72rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      border-radius: 1px;
      transition: background 0.2s;
    }
    .cta-btn:hover { background: #2e2b26; }
    .cta-sub {
      margin-top: 0.7rem;
      font-size: 0.65rem;
      color: var(--muted);
    }

    /* ── FOOTER ── */
    footer {
      background: var(--ink);
      padding: 1.5rem;
      text-align: center;
    }
    .footer-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.2rem;
    }
    .footer-ar {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.85rem;
      color: rgba(184,154,106,0.5);
      margin-bottom: 0.4rem;
    }
    .footer-addr {
      font-size: 0.63rem;
      color: var(--muted);
      line-height: 1.7;
    }
  </style>
</head>
<body>

<!-- HEADER -->
<header>
  <div class="logo">Local <span>Tailor</span></div>
  <div class="header-tag">Bandung · Est. 2026</div>
</header>

<!-- BISMILLAH BAND -->
